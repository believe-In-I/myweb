# 依赖目录
node_modules/

# 构建输出
dist/
dist-ssr/

# Vite 缓存
.vite/

# 环境变量文件（包含敏感信息）
.env
.env.local
.env.*.local
*.env

# 但保留这些非敏感配置
!.env.development
!.env.production

# 日志文件
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 编辑器配置（个人偏好，可根据需要调整）
.idea/
.vscode/
*.swp
*.swo
*.sublime-*

# macOS 系统文件
.DS_Store
Thumbs.db

# 测试覆盖率
coverage/

# 临时文件
*.tmp
*.temp

# 锁文件（使用 npm 时保留）
yarn.lock
# pnpm-lock.yaml

# 后端/服务端文件（如果有独立后端目录）
# oss/
# server/

# 上传文件目录（如果有）
# uploads/
# files/
node_modules
